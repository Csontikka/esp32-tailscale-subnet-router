# assets/ and docs/images/ (scrubbed) instead.
tools/_mockups/

# Dev scratch & agent state — NEVER commit. These contain the device admin
# password, the operator email, real names, the tailnet name, real SSIDs,
# dev-network IPs and exit-node IPs. None of it is part of the firmware.
